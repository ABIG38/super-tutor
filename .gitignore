# Reasonix 工具配置（与项目无关）
.reasonix/

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.egg-info/

# 环境变量（含 API Key）
.env

# 本地模型权重（体积大，应外置）
knowledge_base/models/

# BM25 索引序列化文件（运行时生成）
*.pkl

# ChromaDB 持久化数据（运行时生成）
knowledge_base/index/chroma/
knowledge_base/index/*.db

# 应用日志
knowledge_base/index/logs/
knowledge_base/logs/
logs/

# 用户会话数据（含对话隐私，不应上传）
knowledge_base/index/chats/

# 学习计划文件（个人数据）
knowledge_base/index/plans/

# 崩溃日志
crash.log

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 应用输出
app_output.log
reasonix.toml
.ruff_cache/
.venv/
.pytest_cache/
